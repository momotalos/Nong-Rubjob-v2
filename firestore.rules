rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Demo prototype: allow read/write to demo user documents only
    match /users/{userId} {
      allow read, write: if userId == 'demo_employee' || userId == 'demo_hr';
      match /sessions/{sessionId} {
        allow read, write: if userId == 'demo_employee' || userId == 'demo_hr';
      }
      match /data/{docId} {
        allow read, write: if userId == 'demo_employee' || userId == 'demo_hr';
      }
    }
  }
}
